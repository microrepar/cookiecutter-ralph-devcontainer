{
  "name": "{{cookiecutter.project_name}}",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:{{cookiecutter.timezone}}}",
      "GIT_DELTA_VERSION": "{{cookiecutter.git_delta_version}}",
      "ZSH_IN_DOCKER_VERSION": "{{cookiecutter.zsh_in_docker_version}}",
      "DOCKER_GID": "{{cookiecutter.docker_gid}}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugger",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.python",
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "{{cookiecutter.container_user}}",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/{{cookiecutter.container_user}}/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/{{cookiecutter.container_user}}/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "PYTHONUNBUFFERED": "1"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "sudo /usr/local/bin/init-docker.sh && sudo /usr/local/bin/init-firewall.sh",
  "waitFor": "postStartCommand"
}
