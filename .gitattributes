# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.bash text eol=lf
*.sh text eol=lf
*.zsh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.example text eol=lf
*.gitkeep text eol=lf
Dockerfile* text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=lf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pem binary
